# ─── Nemotron proxy (primary LLM) ────────────────────────────────────────────
# Disclosed in the password-protected user-package zip. Private Cloudflare-
# tunneled LiteLLM proxy in front of nemotron-3-nano-omni (90-day key).
# Keep these private. Never commit a populated .env.

LITELLM_KEY=
PROXY_URL=https://llm-proxy.atlas-horizon.com
NEMOTRON_MODEL=nemotron-3-nano-omni

# Cloudflare Access service-token credentials (required by the proxy)
CF_CLIENT_ID=
CF_CLIENT_SECRET=

# ─── Bahasa fallback (--locale id) ───────────────────────────────────────────
# The Nemotron proxy is single-model (multilingual nemotron-3-nano-omni).
# Set these ONLY if you have a separate Bahasa endpoint (e.g. the local
# llama.cpp from scripts/setup-local-llm.sh, or a Qwen3 NIM). When unset,
# --locale id falls through to nemotron-3-nano-omni.
KLERK_QWEN_BASE_URL=
KLERK_QWEN_MODEL=qwen/qwen3-235b-instruct

# ─── Stretch fallbacks (optional, not used by default) ───────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
KLERK_LLM_FALLBACK=0

# ─── Google Drive (optional ingestion path) ──────────────────────────────────
# Service account JSON path; only needed if you want klerk to pull from Drive.
GOOGLE_APPLICATION_CREDENTIALS=.secrets/service-account.json
DRIVE_FOLDER_ID=

# ─── Parser ──────────────────────────────────────────────────────────────────
# `docling` (default) | `pymupdf` (fallback for torch/easyocr install issues)
KLERK_PARSER=docling

# ─── Observability ───────────────────────────────────────────────────────────
# Phoenix is embedded (SQLite-backed); these are usually fine as defaults.
PHOENIX_WORKING_DIR=.phoenix
PHOENIX_PORT=6006

# ─── Cache ───────────────────────────────────────────────────────────────────
KLERK_DISKCACHE_DIR=.diskcache
KLERK_SEMANTIC_CACHE_THRESHOLD=0.95
KLERK_SEMANTIC_CACHE=1

# ─── LanceDB ─────────────────────────────────────────────────────────────────
KLERK_LANCEDB_DIR=.lancedb

# ─── Locale ──────────────────────────────────────────────────────────────────
# Default for `klerk ask` / `klerk propose` if --locale not given.
KLERK_DEFAULT_LOCALE=en

# ─── Backwards-compat (the pre-zip plan used these; still honored) ───────────
# Set EITHER LITELLM_KEY+PROXY_URL+CF_* above (preferred), OR the legacy
# trio below. Leave the unused set blank.
NVIDIA_API_KEY=
NVIDIA_NIM_BASE_URL=
NVIDIA_NIM_MODEL=
