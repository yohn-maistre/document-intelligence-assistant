# ─── Nemotron proxy (the only LLM klerk uses) ────────────────────────────────
# Provided in the password-protected user-package zip. Private Cloudflare-
# tunneled LiteLLM proxy in front of nemotron-3-nano-omni (90-day key).
# Never commit a populated .env.

LITELLM_KEY=
PROXY_URL=https://llm-proxy.atlas-horizon.com

# Cloudflare Access service-token credentials (required by the proxy).
CF_CLIENT_ID=
CF_CLIENT_SECRET=

# Pinned model — do not swap to a different Nemotron variant; the brief
# treats this model ID as the contract.
NEMOTRON_MODEL=nemotron-3-nano-omni

# ─── Google Drive ingestion ──────────────────────────────────────────────────
# Service Account JSON path; reviewer shares the Drive folder with the SA email.
GOOGLE_APPLICATION_CREDENTIALS=.secrets/service-account.json
DRIVE_FOLDER_ID=

# ─── Embedding backend ───────────────────────────────────────────────────────
# `local` (default; BGE-M3 via FlagEmbedding, needs the `local`/`full` extra) |
# `remote` (OpenAI-compatible /embeddings, for lite demos) | `mock` (CI / sandbox).
KLERK_EMBED_BACKEND=local
# Remote backend config (only used when KLERK_EMBED_BACKEND=remote). Provider-
# neutral OpenAI-compatible endpoint; the model MUST emit 1024-d vectors to
# match the LanceDB schema. e.g. DeepInfra / Jina / OpenRouter.
KLERK_EMBED_REMOTE_URL=
KLERK_EMBED_REMOTE_KEY=
KLERK_EMBED_REMOTE_MODEL=

# ─── Parser ──────────────────────────────────────────────────────────────────
# `docling` (default) | `pymupdf` (fallback for torch/easyocr install issues)
KLERK_PARSER=docling

# ─── Observability ───────────────────────────────────────────────────────────
PHOENIX_WORKING_DIR=.phoenix
PHOENIX_PORT=6006

# ─── Storage paths ───────────────────────────────────────────────────────────
KLERK_LANCEDB_DIR=.lancedb
KLERK_DISKCACHE_DIR=.diskcache

# ─── Locale ──────────────────────────────────────────────────────────────────
KLERK_DEFAULT_LOCALE=en

# ─── Studio TUI ──────────────────────────────────────────────────────────────
# Textual theme name for the Studio dashboard (terminal + textual-serve).
KLERK_TUI_THEME=textual-dark

# Embeddings via HuggingFace Inference (KLERK_EMBED_BACKEND=hf) — reuses HF_TOKEN.
# Great for the lite/phone path: no 1.2GB local download, HF does the embedding.
# KLERK_EMBED_HF_MODEL=BAAI/bge-m3
# KLERK_EMBED_HF_URL=   # override if HF changes the feature-extraction route
# KLERK_EMBED_HF_KEY=   # defaults to HF_TOKEN / HUGGING_FACE_HUB_TOKEN
