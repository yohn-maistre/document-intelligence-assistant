# ─── Nemotron NIM (primary LLM) ──────────────────────────────────────────────
# Public NIM contract; update if the password-zip reveals a private endpoint.
NVIDIA_API_KEY=
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_NIM_MODEL=nvidia/nemotron-4-340b-instruct

# ─── Bahasa fallback (--locale id) ───────────────────────────────────────────
# Optional. Routes Bahasa Q&A through this model when --locale id is passed.
KLERK_QWEN_MODEL=qwen/qwen3-235b-instruct
KLERK_QWEN_BASE_URL=https://integrate.api.nvidia.com/v1

# ─── Stretch fallbacks ───────────────────────────────────────────────────────
# Only used if Nemotron is unreachable and KLERK_LLM_FALLBACK=1
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
KLERK_LLM_FALLBACK=0

# ─── Google Drive (optional ingestion path) ──────────────────────────────────
# Service account JSON path; only needed if you want klerk to pull from Drive.
GOOGLE_APPLICATION_CREDENTIALS=.secrets/service-account.json
DRIVE_FOLDER_ID=

# ─── Parser ──────────────────────────────────────────────────────────────────
# `docling` (default) | `pymupdf` (fallback for torch/easyocr install issues)
KLERK_PARSER=docling

# ─── Observability ───────────────────────────────────────────────────────────
# Phoenix is embedded (SQLite-backed); these are usually fine as defaults.
PHOENIX_WORKING_DIR=.phoenix
PHOENIX_PORT=6006

# ─── Cache ───────────────────────────────────────────────────────────────────
KLERK_DISKCACHE_DIR=.diskcache
KLERK_SEMANTIC_CACHE_THRESHOLD=0.95

# ─── LanceDB ─────────────────────────────────────────────────────────────────
KLERK_LANCEDB_DIR=.lancedb

# ─── Locale ──────────────────────────────────────────────────────────────────
# Default for `klerk ask` / `klerk propose` if --locale not given.
KLERK_DEFAULT_LOCALE=en
